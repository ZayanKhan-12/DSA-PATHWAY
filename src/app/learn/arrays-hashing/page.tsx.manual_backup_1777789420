fn two_sum(nums: Vec<i32>, target: i32) -> Vec<i32> {
    let mut seen: HashMap<i32, i32> = HashMap::new();

    for (i, &value) in nums.iter().enumerate() {
        let need = target - value;

        if let Some(&idx) = seen.get(&need) {
